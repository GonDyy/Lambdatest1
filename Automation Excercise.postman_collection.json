  "item": [
    {
      "name": "Get All Products List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "jsonData = pm.response.json();",
              "",
              "pm.test(\"Business responseCode is 200\", function () {",
              "    pm.expect(jsonData).to.have.property(\"responseCode\");",
              "    pm.expect(jsonData.responseCode).to.eql(200);",
              "});",
              "",
              "pm.test(\"Response contains products array\", function () {",
              "    pm.expect(jsonData).to.have.property(\"products\");",
              "    pm.expect(jsonData.products).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Products array is not empty\", function () {",
              "    pm.expect(jsonData.products.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test(\"Each product has required core fields\", function () {",
              "    jsonData.products.forEach(function (product) {",
              "        pm.expect(product).to.have.property(\"id\");",
              "        pm.expect(product).to.have.property(\"name\");",
              "        pm.expect(product).to.have.property(\"price\");",
              "        pm.expect(product).to.have.property(\"brand\");",
              "        pm.expect(product).to.have.property(\"category\");",
              "    });",
              "});",
              "",
              "pm.test(\"Each required field has correct data type\", function () {",
              "    jsonData.products.forEach(function (product) {",
              "        pm.expect(product.id).to.be.a(\"number\");",
              "        pm.expect(product.name).to.be.a(\"string\").and.not.empty;",
              "        pm.expect(product.price).to.be.a(\"string\").and.not.empty;",
              "        pm.expect(product.brand).to.be.a(\"string\").and.not.empty;",
              "        pm.expect(product.category).to.be.an(\"object\");",
              "    });",
              "});",
              "",
              "pm.test(\"Nested category structure is valid\", function () {",
              "    jsonData.products.forEach(function (product) {",
              "        pm.expect(product.category).to.have.property(\"category\");",
              "        pm.expect(product.category.category).to.be.a(\"string\").and.not.empty;",
              "",
              "        pm.expect(product.category).to.have.property(\"usertype\");",
              "        pm.expect(product.category.usertype).to.be.an(\"object\");",
              "        pm.expect(product.category.usertype).to.have.property(\"usertype\");",
              "        pm.expect(product.category.usertype.usertype).to.be.a(\"string\").and.not.empty;",
              "    });",
              "});",
              "",
              "pm.test(\"Product IDs are unique\", function () {",
              "    const ids = jsonData.products.map(function (product) {",
              "        return product.id;",
              "    });",
              "    const uniqueIds = new Set(ids);",
              "    pm.expect(uniqueIds.size).to.eql(ids.length);",
              "});",
              "",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
